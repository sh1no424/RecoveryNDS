&НаКлиенте
Процедура НайтиОстатки(Команда)
	Если Не ЗначениеЗаполнено(Объект.Организация) Или Не ЗначениеЗаполнено(Объект.ДатаОстатков) Тогда
		Сообщить("Заполните Организацию и Дату остатков!");
		Возврат;
	КонецЕсли;
	
	НайтиОстаткиНаСервере();
	Сообщить("Поиск завершен. Проверьте таблицу перед формированием документов.");
КонецПроцедуры

&НаКлиенте
Процедура СформироватьДокументы(Команда)
	Если Объект.ТаблицаОстатков.Количество() = 0 Тогда
		Сообщить("Таблица пуста! Сначала нажмите 'Найти остатки'.");
		Возврат;
	КонецЕсли;

	Оповещение = Новый ОписаниеОповещения("ПослеВопроса", ЭтотОбъект);
	ПоказатьВопрос(Оповещение, "Создать документы на основании данных в таблице?", РежимДиалогаВопрос.ДаНет);
КонецПроцедуры

&НаКлиенте
Процедура ПослеВопроса(Результат, ДополнительныеПараметры) Экспорт
	Если Результат = КодВозвратаДиалога.Да Тогда
		ОчиститьСообщения();
		ТекстРезультата = СформироватьНаСервере();
		Сообщить(ТекстРезультата);
	КонецЕсли;
КонецПроцедуры

&НаСервере
Процедура НайтиОстаткиНаСервере()
	
	Объект.ТаблицаОстатков.Очистить();
	ДатаГраницы = КонецДня(Объект.ДатаОстатков);
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	УСНОстатки.Партия КАК Партия,
		|	УСНОстатки.ЭлементРасхода КАК Номенклатура,
		|	УСНОстатки.СчетУчета КАК СчетУчета,
		|	ЕСТЬNULL(УСНОстатки.НДСОстаток, 0) КАК СуммаНДС,
		|	ЕСТЬNULL(УСНОстатки.СуммаОстаток, 0) КАК СуммаВсего,
		|	ЕСТЬNULL(ПоступлениеТовары.СтавкаНДС, ЗНАЧЕНИЕ(Перечисление.СтавкиНДС.НДС20)) КАК СтавкаНДС
		|ИЗ
		|	РегистрНакопления.РасходыПриУСН.Остатки(&Период, Организация = &Организация И СчетУчета В ИЕРАРХИИ (&Счет41)) КАК УСНОстатки
		|		ЛЕВОЕ СОЕДИНЕНИЕ Документ.ПоступлениеТоваровУслуг.Товары КАК ПоступлениеТовары
		|		ПО УСНОстатки.Партия = ПоступлениеТовары.Ссылка 
		|		И УСНОстатки.ЭлементРасхода = ПоступлениеТовары.Номенклатура
		|ГДЕ
		|	УСНОстатки.НДСОстаток > 0";
	
	Запрос.УстановитьПараметр("Период",      ДатаГраницы);
	Запрос.УстановитьПараметр("Организация", Объект.Организация);
	Запрос.УстановитьПараметр("Счет41",      Объект.СчетУчета);
	
	Выборка = Запрос.Выполнить().Выбрать();
	
	Пока Выборка.Следующий() Цикл
		НоваяСтрока = Объект.ТаблицаОстатков.Добавить();
		ЗаполнитьЗначенияСвойств(НоваяСтрока, Выборка);
	КонецЦикла;
	
КонецПроцедуры

&НаСервере
&НаСервере
Функция СформироватьНаСервере()
	
	ДатаГраницы = КонецДня(Объект.ДатаОстатков);
	ДатаДокументов = НачалоДня(Объект.ДатаОстатков) + 86400; 
	СтрокаПоиска = "Выделение НДС из остатков (переход на ОСНО 2026)"; 

	ЗапросОп = Новый Запрос;
	ЗапросОп.Текст = 
		"ВЫБРАТЬ ПЕРВЫЕ 1 Ссылка ИЗ Документ.ОперацияБух 
		|ГДЕ Организация = &Орг И Дата = &Дата И Содержание = &Сод И НЕ ПометкаУдаления";
	ЗапросОп.УстановитьПараметр("Орг",  Объект.Организация);
	ЗапросОп.УстановитьПараметр("Дата", ДатаГраницы);
	ЗапросОп.УстановитьПараметр("Сод",  СтрокаПоиска);
	
	ВыборкаОп = ЗапросОп.Выполнить().Выбрать();
	Если ВыборкаОп.Следующий() Тогда
		ДокОперация = ВыборкаОп.Ссылка.ПолучитьОбъект();
		ДокОперация.Движения.Хозрасчетный.Очистить(); 
	Иначе
		ДокОперация = Документы.ОперацияБух.СоздатьДокумент();
		ДокОперация.Дата = ДатаГраницы;
		ДокОперация.Организация = Объект.Организация;
		ДокОперация.Содержание = СтрокаПоиска;
	КонецЕсли;
	
	СуммаИтого = 0;
	Для Каждого Стр Из Объект.ТаблицаОстатков Цикл
		Проводка = ДокОперация.Движения.Хозрасчетный.Добавить();
		Проводка.Организация = Объект.Организация;
		Проводка.Период      = ДокОперация.Дата;
		Проводка.Сумма       = Стр.СуммаНДС;
		Проводка.СчетДт = ПланыСчетов.Хозрасчетный.НДСПоПриобретеннымМПЗ;
		Проводка.СубконтоДт[Проводка.СчетДт.ВидыСубконто[0].ВидСубконто] = Стр.Партия.Контрагент;
		Проводка.СубконтоДт[Проводка.СчетДт.ВидыСубконто[1].ВидСубконто] = Стр.Партия;
		
		СчетДляСписания = ?(ЗначениеЗаполнено(Стр.СчетУчета), Стр.СчетУчета, Объект.СчетУчета);
		Проводка.СчетКт = СчетДляСписания;
		Проводка.СубконтоКт[Проводка.СчетКт.ВидыСубконто[0].ВидСубконто] = Стр.Номенклатура;
		Если Проводка.СчетКт.ВидыСубконто.Количество() > 2 Тогда
			Проводка.СубконтоКт[Проводка.СчетКт.ВидыСубконто[2].ВидСубконто] = Стр.Партия;
		КонецЕсли;
		СуммаИтого = СуммаИтого + Стр.СуммаНДС;
	КонецЦикла;
	ДокОперация.СуммаОперации = СуммаИтого;
	ДокОперация.Записать();

	ТЗ_Партии = Объект.ТаблицаОстатков.Выгрузить();
	ТЗ_Партии.Свернуть("Партия");
	
	Для Каждого СтрПартия Из ТЗ_Партии Цикл
		
		ЗапросВычет = Новый Запрос;
		ЗапросВычет.Текст = 
			"ВЫБРАТЬ ПЕРВЫЕ 1 Ссылка ИЗ Документ.ОтражениеНДСКВычету 
			|ГДЕ РасчетныйДокумент = &Партия И Организация = &Орг И НЕ ПометкаУдаления";
		ЗапросВычет.УстановитьПараметр("Партия", СтрПартия.Партия);
		ЗапросВычет.УстановитьПараметр("Орг",    Объект.Организация);
		
		ВыборкаВычет = ЗапросВычет.Выполнить().Выбрать();
		Если ВыборкаВычет.Следующий() Тогда
			ДокВычет = ВыборкаВычет.Ссылка.ПолучитьОбъект();
			ДокВычет.ТоварыИУслуги.Очистить(); 
		Иначе
			ДокВычет = Документы.ОтражениеНДСКВычету.СоздатьДокумент();
			ДокВычет.Дата = ДатаДокументов;
			ДокВычет.Организация = Объект.Организация;
			ДокВычет.РасчетныйДокумент = СтрПартия.Партия;
		КонецЕсли;

		ДокВычет.Контрагент = СтрПартия.Партия.Контрагент;
		ДокВычет.ДоговорКонтрагента = СтрПартия.Партия.ДоговорКонтрагента;
		ДокВычет.ПрямаяЗаписьВКнигу = Истина;
		ДокВычет.ФормироватьПроводки = Истина;
		ДокВычет.ИспользоватьДокументРасчетовКакСчетФактуру = Истина;
		ДокВычет.КодВидаОперации = "01";
		
		Отбор = Новый Структура("Партия", СтрПартия.Партия);
		СтрокиДляТЧ = Объект.ТаблицаОстатков.НайтиСтроки(Отбор);
		
		Для Каждого ТекСтрока Из СтрокиДляТЧ Цикл
			НоваяСтрока = ДокВычет.ТоварыИУслуги.Добавить();
			НоваяСтрока.ВидЦенности = Перечисления.ВидыЦенностей.Товары;
			НоваяСтрока.Сумма = ТекСтрока.СуммаВсего - ТекСтрока.СуммаНДС;
			НоваяСтрока.СуммаНДС = ТекСтрока.СуммаНДС;
			НоваяСтрока.СтавкаНДС = ?(ЗначениеЗаполнено(ТекСтрока.СтавкаНДС), ТекСтрока.СтавкаНДС, Перечисления.СтавкиНДС.НДС20);
			НоваяСтрока.СчетУчетаНДС = ПланыСчетов.Хозрасчетный.НДСПоПриобретеннымМПЗ;
			НоваяСтрока.Событие = Перечисления.СобытияПоНДСПокупки.ПредъявленНДСКВычету;
		КонецЦикла;
		
		Попытка
			ДокВычет.Записать(РежимЗаписиДокумента.Проведение);
		Исключение
			ДокВычет.Записать(РежимЗаписиДокумента.Запись);
		КонецПопытки;
	КонецЦикла;
	
	Возврат "Обработка завершена! Обновлено/Создано документов для " + ТЗ_Партии.Количество() + " партий.";
	
КонецФункции